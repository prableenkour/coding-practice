#include <iostream>
using namespace std;

class Node {
public:
    int data;
    Node* prev;
    Node* next;

    Node(int val) {
        data = val;
        prev = nullptr;
        next = nullptr;
    }
};

void traverse(Node* head) {
    while (head) {
        cout << head->data << " ";
        head = head->next;
    }
    cout << endl;
}
void addAtStart(Node*& head, int val) {
    Node* newNode = new Node(val);

    if (head != nullptr) {
        newNode->next = head;
        head->prev = newNode;
    }

    head = newNode;
}
void addatend(Node*& head,int val)
{
    Node* newNode = new Node(val);
    if(!head) {
        head = newNode;
        return;
    }
    Node* temp = head;
    while(temp->next) {
        temp = temp->next;
    }
    temp->next = newNode;
    newNode->prev = temp;
}
int main() {
    Node* head = nullptr;

    Node* n1 = new Node(5);
    Node* n2 = new Node(10);
    Node* n3 = new Node(15);
    Node* n4 = new Node(20);
    Node* n5 = new Node(25);
    head = n1;

    n1->next = n2;
    n2->prev = n1;

    n2->next = n3;
    n3->prev = n2;

    n3->next = n4;
    n4->prev = n3;

    n4->next = n5;
    n5->prev = n4;

    addAtStart(head, 0);
    traverse(head);

    return 0;
}